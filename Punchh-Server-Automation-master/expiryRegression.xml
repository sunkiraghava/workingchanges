<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Local Regression Suite" parallel="classes" thread-count="10" preserve-order="true">

	<parameter name="BROWSER" value="chrome" />
	<parameter name="RUNTYPE" value="local" />
	<parameter name="HUB_HOST" value="localhost" /> <!-- 192.168.43.152 -->
	<parameter name="suite" value="localRegression" />
	<parameter name="environment" value="pp" />
    <parameter name="zephyrExecution" value="true" />

	<listeners>
		<!-- <listener class-name="com.punchh.server.utilities.Transformer" /> -->
		<listener
			class-name="com.punchh.server.utilities.TestListeners" />
	</listeners>
 
	<test name="Regression Test" preserve-order="true">
		<classes>
			<class name="Support.ConfigurationClass" />
			<class name="com.punchh.server.LP1Test.MigrationStrategyTest"/>
			<class name="com.punchh.server.LP1Test.MigrationStrategyAndApiTest"/>
      		<class name="com.punchh.server.LP1Test.RollingExpiryTest"/> 
			<class name="com.punchh.server.LP1Test.DecoupleRollingExpiryTest"/> 
			<class name="com.punchh.server.LP1Test.DecoupleRollingExpiryAndApiTest"/> 
 			<class name="com.punchh.server.Test.ExpiryStrategyTest"/>
			<class name="com.punchh.server.LP1Test.MembershipAcctSummaryPURTest"/>
            <class name="com.punchh.server.LP1Test.MembershipAcctSummaryPTCTest"/>
            <class name="com.punchh.server.LP1Test.RollingCheckinSumTest"/> 
			<class name="com.punchh.server.LP1Test.DecoupleRollingExpiryRollingCheckinSumPTRTest"/>
			<class name="com.punchh.server.LP1Test.MembershipLevelDecouplingTest"/>	
			<class name="com.punchh.server.LP1Test.DecoupleRollingExpiryTestPTCTest"/>
			<class name="com.punchh.server.LP1Test.DecoupleRollingExpiryRollingCheckinSumPTCTest"/>	
			<class name="com.punchh.server.LP1Test.MigrationStrategyExcludeCategoryTest"/>	
		</classes>
	</test>
</suite> <!-- Suite -->
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="API Test Suite" preserve-order="true" parallel="classes" thread-count="10">
	

	<parameter name="BROWSER" value="chrome" />
	<parameter name="RUNTYPE" value="local" />
	<parameter name="HUB_HOST" value="localhost" /> <!-- 192.168.43.152 -->
	<parameter name="environment" value="saurabh_local" />
	<listeners>
		<!-- <listener class-name="com.punchh.server.utilities.Transformer"/> -->
		<listener
			class-name="com.punchh.server.utilities.TestListeners" />
	</listeners>

	<test name="AdvancedAuth">
		<classes>
			<class name="Support.ConfigurationClass" />
	<class name="com.punchh.server.Integration2.AdvancedAuthAPITest" />
            <class name="com.punchh.server.Integration2.AdvancedAuthGUITest" />
            <class name="com.punchh.server.Integration2.AdvancedAuthNegativeTest" />
		

			
			
		</classes>
	</test>
</suite> <!-- Suite -->

<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Regression Suite" preserve-order="true" parallel="classes" thread-count="10">

	<parameter name="BROWSER" value="chrome" />
	<parameter name="RUNTYPE" value="local" />
	<parameter name="HUB_HOST" value="" /> <!-- 192.168.43.152/localhost -->
	<parameter name="suite" value="regression" />
	<parameter name="environment" value="pp" />
	<parameter name="zephyrExecution" value="false" />

	<listeners>
		<listener class-name="com.punchh.server.utilities.TestListeners" />	
	</listeners>

	<test name="Regression Test" preserve-order="true">
		<classes>
			<class name="Support.ConfigurationClass" />
			<class name="com.punchh.server.segmentsTest.SegmentCampaignTest"/>
			<class name="com.punchh.server.segmentsTest.SegmentAndMassCampaignTest"/>
			<class name="com.punchh.server.segmentsTest.CampaignWithTransactionalAndNonTransactionalSegmentTest"/>
			<class name="com.punchh.server.segmentsTest.SmartSegmentsTest"/>
			<class name="com.punchh.server.segmentsTest.SegmentWithLocationTest"/>
			<class name="com.punchh.server.segmentsTest.SegmentExportTest"/>
			<class name="com.punchh.server.segmentsTest.NewSegmentHomePageTest"/>
			<class name="com.punchh.server.segmentsTest.Segments_OnBoardingChannel"/> 
			<class name="com.punchh.server.segmentsTest.CustomSegmentWithSignupCampaign" />
			<class name="com.punchh.server.segmentsTest.PunchhSegmentTest"/>
			<class name="com.punchh.server.segmentsTest.SegmentEligibilityAPITest"/>
			<class name="com.punchh.server.segmentsTest.SegmentPageLinksAndButtonTest"/>
			<class name="com.punchh.server.segmentsTest.DigitalPaymentZipcodeSegmentTest"/>
			<class name="com.punchh.server.segmentsTest.SegmentAndChallengeCampaignTest"/>
			<class name="com.punchh.server.segmentsTest.NonLoyaltyGuestSegmentTest"/>
		</classes>
	</test>
</suite> <!-- Suite -->
